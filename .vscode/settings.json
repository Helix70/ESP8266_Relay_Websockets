{
    "files.associations": {
        "*.c": "c",
        "*.h": "c",
        "string": "cpp"
    },
    "cmake.configureOnOpen": false,
    "terminal.integrated.stickyScroll.enabled": false,
    "cmake.ignoreCMakeListsMissing": true,
    "cmake.enableAutomaticKitScan": false,
    "cmake.sourceDirectory": "${workspaceFolder}/nonexistent"
}